# This patch can be applied to test.py script to allow launching only examples
# and tests from a specific module.
# For example: python3 test.py --jobs=8 --module-only=satellite
#
# TO apply this patch: patch < test.py.patch

diff --git a/test.py b/test.py
index 941987840..7994782a6 100755
--- a/test.py
+++ b/test.py
@@ -15,6 +15,7 @@ import sys
 import threading
 import time
 import xml.etree.ElementTree as ET
+import re
 
 from utils import get_list_from_file
 
@@ -1205,6 +1206,21 @@ def load_previously_successful_tests():
     return previously_run_tests_to_skip
 
 
+def get_all_tests_from_module(module_name):
+    tests_of_module = []
+    tests_directory = os.path.join(os.getcwd(), "contrib", module_name, "test")
+    cmd = ["grep", "-rnI", "TestSuite", tests_directory]
+    result = subprocess.run(cmd, capture_output=True, text=True).stdout.split('\n')
+
+    for value in result:
+        match = re.match(r'.*TestSuite\s*\(\s*\"\s*([a-zA-Z_-]+)\s*\"\s*,\s*[a-zA-Z:]*Type::\w+\s*\).*', value)
+        if match:
+            first_arg = match.group(1)
+            tests_of_module.append(first_arg)
+
+    return tests_of_module
+
+
 #
 # This is the main function that does the work of interacting with the
 # test-runner itself.
@@ -1297,27 +1313,31 @@ def run_tests():
     example_tests = []
     example_names_original = []
     python_tests = []
